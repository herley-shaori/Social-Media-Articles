    s --> cases3["EMAIL / SMS / PUSH / WHATSAPP"]
    r --> cases4["EMAIL / SMS / PUSH / WHATSAPP"]

    note["Add a channel = edit all four switches.<br/>Miss one (validate) and it still compiles —<br/>the failure only appears at runtime."]
