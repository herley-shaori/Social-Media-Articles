apiVersion: apps/v1
kind: Deployment
metadata:
  name: headroom
  labels:
    app: headroom
spec:
  replicas: __REPLICAS__
  selector:
    matchLabels:
      app: headroom
  template:
    metadata:
      labels:
        app: headroom
    spec:
      priorityClassName: headroom
      nodeSelector:
        kwok-nodegroup: burst
      terminationGracePeriodSeconds: 0
      containers:
        - name: pause
          image: registry.k8s.io/pause:3.9
          # Same footprint as a burst pod, so N pause pods reserve room for N real pods.
          resources:
            requests:
              cpu: "1"
              memory: 512Mi
            limits:
              cpu: "1"
              memory: 512Mi
